      "id": "VF-2026-001",
      "severity": "CRITICAL",
      "cvss_score": 7.5,
      "title": "CORS Misconfiguration - Allow All Origins",
      "cwe": "CWE-942",
      "location": {
        "file": "backend/main.py",
        "lines": "199-207"
      },
      "description": "Backend API allows requests from ANY origin, enabling malicious websites to make authenticated requests on behalf of users.",
      "impact": {
        "attack_vector": "Network",
        "attack_complexity": "Low",
        "privileges_required": "None",
        "user_interaction": "Required",
        "confidentiality": "Low",
        "integrity": "Low",
        "availability": "None"
      },
      "remediation": "Restrict allow_origins to specific trusted domains instead of wildcard '*'",
      "code_fix": {
        "before": "allow_origins=[\"*\"]",
        "after": "allow_origins=[\"http://localhost:3000\", \"http://localhost:3001\"]"
      },
      "priority": "IMMEDIATE",
      "status": "OPEN"
    },
    {
      "id": "VF-2026-002",
      "severity": "CRITICAL",
      "cvss_score": 8.0,
      "title": "Missing Authentication on Critical Endpoints",
      "cwe": "CWE-306",
      "location": {
        "file": "backend/main.py",
        "endpoints": [
          "/process_cover",
          "/upload_model",
          "/demucs_separate",
          "/delete_model/{model_id}",
          "/preview",
          "/clean_temp_files",
          "/unload_models"
        ]
      },
      "description": "Multiple critical endpoints have no authentication, allowing anyone to use GPU resources, upload malicious models, or delete data.",
      "impact": {
        "attack_vector": "Network",
        "attack_complexity": "Low",
        "privileges_required": "None",
        "user_interaction": "None",
        "scope": "Changed",
        "confidentiality": "None",
        "integrity": "Low",
        "availability": "High"
      },
      "remediation": "Implement HTTP Bearer token authentication on all sensitive endpoints",
      "code_fix": {
        "type": "Add authentication middleware",
        "example": "async def verify_auth(credentials: HTTPAuthorizationCredentials = Depends(security))"
      },
      "priority": "IMMEDIATE",
      "status": "OPEN"
    },
    {
