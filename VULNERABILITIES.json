      "severity": "MEDIUM",
      "cvss_score": 6.5,
      "title": "File Upload Without Validation",
      "cwe": "CWE-434",
      "location": {
        "file": "backend/main.py",
        "endpoints": [
          "/upload_model",
          "/process_cover"
        ]
      },
      "description": "File upload endpoints accept any file type without extension validation, MIME type checking, or file size limits.",
      "attack_scenarios": [
        "Upload PHP/Python shell for Remote Code Execution",
        "Upload executable for malware deployment",
        "Upload huge file for DoS via disk exhaustion",
        "Upload malicious model weights for model poisoning"
      ],
      "remediation": "Implement file extension whitelist, MIME type validation, and file size limits",
      "priority": "WITHIN_1_WEEK",
      "status": "OPEN"
    },
    {
      "id": "VF-2026-004",
      "severity": "MEDIUM",
      "cvss_score": 6.0,
      "title": "Path Traversal in File Serving",
      "cwe": "CWE-22",
      "location": {
        "file": "backend/main.py",
        "lines": "216-240",
        "endpoint": "/tracks/{filename:path}"
      },
      "description": "The filename parameter is not sanitized, allowing path traversal attacks via '../' sequences.",
      "attack_examples": [
        "GET /tracks/../../backend/main.py",
        "GET /tracks/../../../.env",
        "GET /tracks/..%2F..%2F..%2Fetc%2Fpasswd"
      ],
      "remediation": "Use pathlib.Path.resolve() and verify path is within OUTPUT_DIR",
      "code_fix": {
        "type": "Add path validation",
        "example": "file_path.relative_to(output_dir_resolved)"
      },
      "priority": "WITHIN_1_WEEK",
      "status": "OPEN"
    },
