# VocalForge Backend Configuration Example
# Copy this file to .env and update values

# API Authentication Token - CHANGE THIS IN PRODUCTION!
# Generate secure token: python -c "import secrets; print(secrets.token_urlsafe(32))"
VOCALFORGE_API_TOKEN=your-secure-token-here

# Output directory for generated audio files
OUTPUT_DIR=D:\\VocalForge\\backend\\output

# Models directory
MODELS_DIR=D:\\VocalForge\\backend\\models

# Debug mode (False in production)
DEBUG=False

# ACE-Step API URL
ACE_STEP_API=http://localhost:8001

# GPU Settings
CUDA_DEVICE=auto
